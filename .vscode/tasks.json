{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Sterling: Implement Design Doc",
      "type": "shell",
      "command": "python",
      "args": [
        "${workspaceFolder}/tools/implement_design.py",
        "${file}"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "ANTHROPIC_API_KEY": "${env:ANTHROPIC_API_KEY}"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": [],
      "runOptions": {
        "instanceLimit": 1
      },
      "detail": "Reads the currently open design doc and generates Sterling OMS Java source files using Claude. Requires ANTHROPIC_API_KEY to be set."
    },
    {
      "label": "Sterling: Implement Design Doc (dry run)",
      "type": "shell",
      "command": "python",
      "args": [
        "${workspaceFolder}/tools/implement_design.py",
        "--dry-run",
        "${file}"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "ANTHROPIC_API_KEY": "${env:ANTHROPIC_API_KEY}"
        }
      },
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": [],
      "detail": "Dry-run: prints the Claude response without writing files or committing."
    },
    {
      "label": "Sterling: Implement Design Doc (no commit)",
      "type": "shell",
      "command": "python",
      "args": [
        "${workspaceFolder}/tools/implement_design.py",
        "--no-commit",
        "${file}"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "ANTHROPIC_API_KEY": "${env:ANTHROPIC_API_KEY}"
        }
      },
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": [],
      "detail": "Generates and writes files, runs mvn compile, but does not git commit."
    }
  ]
}